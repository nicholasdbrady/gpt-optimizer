# GPT Optimizer — API keys
OPENAI_API_KEY=sk-your-key-here

# Optional: override the model used for checker/rewriter agents (default: gpt-5.4)
# OPTIMIZER_MODEL=gpt-5.4

# Optional: Azure OpenAI endpoint (uses DefaultAzureCredential for auth)
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/openai/v1/

# Optional: Azure Foundry deployment
# AZURE_AI_PROJECT_ENDPOINT=https://your-project.services.ai.azure.com/api
# FOUNDRY_MODEL_DEPLOYMENT_NAME=gpt-5-mini
