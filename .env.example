# GPT Optimizer — Azure OpenAI configuration
#
# Authentication: Run `az login` for Microsoft Entra ID (default).
# Alternatively, set an api_key via the --api-key CLI flag.

# Azure OpenAI endpoint (required — defaults to swdn-resource)
AZURE_OPENAI_ENDPOINT=https://swdn-resource.openai.azure.com/openai/v1/

# Foundry project endpoint (for agent deployment)
AZURE_AI_PROJECT_ENDPOINT=https://swdn-resource.services.ai.azure.com/api/projects/foundry-project

# Optional: override the model used for optimizer agents (default: gpt-5.4)
# OPTIMIZER_MODEL=gpt-5.4
